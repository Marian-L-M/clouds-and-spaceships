{
  "version": 3,
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    },
    { "name": "sidebar", "title": "Sidebar", "area": "uncategorized" },
    {
      "name": "sidebar-right",
      "title": "Sidebar Right",
      "area": "uncategorized"
    }
  ],
  "customTemplates": [
    {
      "name": "wiki",
      "title": "Wiki Single Template",
      "postTypes": ["wiki"]
    }
  ],
  "settings": {
    "useRootPaddingAwareAlignments": true,
    "appearanceTools": true,
    "spacing": {
      "blockGap": true,
      "spacingScale": {
        "operator": "*",
        "increment": 1.5,
        "steps": 7,
        "mediumStep": 1.5,
        "unit": "rem"
      }
    },
    "layout": {
      "contentSize": "min(92%, 1200px)",
      "wideSize": "1600px"
    },
    "typography": {
      "fluid": true,
      "fontFamilies": [
        {
          "slug": "system",
          "name": "System Default",
          "fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen-Sans, Ubuntu, Cantarell, \"Helvetica Neue\", sans-serif"
        },
        {
          "slug": "sans-serif",
          "name": "Sans-serif (Arial)",
          "fontFamily": "Arial, \"Helvetica Neue\", Helvetica, sans-serif"
        },
        {
          "slug": "serif",
          "name": "Serif (Georgia)",
          "fontFamily": "Georgia, Cambria, \"Times New Roman\", Times, serif"
        },
        {
          "slug": "monospace",
          "name": "Monospace",
          "fontFamily": "\"SFMono-Regular\", Consolas, \"Liberation Mono\", Menlo, Courier, monospace"
        }
      ],
      "fontStyle": true,
      "fontWeight": true,
      "letterSpacing": true,
      "textDecoration": true,
      "lineHeight": true,
      "textTransform": true,
      "writingMode": true,
      "dropCap": true,
      "textColumns": true,
      "customFontSize": true,
      "fontSizes": [
        {
          "slug": "large",
          "size": "clamp(1.6rem, 2.2vw, 1.8rem)"
        },
        {
          "slug": "medium",
          "size": "clamp(1.4rem, 2vw, 1.6rem)"
        },
        {
          "slug": "small",
          "size": "clamp(1.3rem, 1.8vw, 1.5rem)"
        }
      ]
    },
    "blocks": {
      "core/button": {
        "border": {
          "color": false,
          "radius": false,
          "style": false,
          "width": false
        }
      },
      "cns-theme/cns-sidebar": {
        "color": {
          "text": true
        }
      }
    },
    "color": {
      "background": true,
      "text": true,
      "link": true,
      "custom": true,
      "defaultPalette": false,
      "duotone": [],
      "customDuotone": false,
      "gradients": [],
      "customGradient": false,
      "palette": [
        {
          "slug": "primary",
          "color": "#4E16A8",
          "name": "Primary"
        },
        {
          "slug": "secondary",
          "color": "#2F5281",
          "name": "Secondary"
        },
        {
          "slug": "background",
          "color": "#FFFFFF",
          "name": "Background"
        },
        {
          "slug": "text-strong",
          "color": "#000000",
          "name": "Text"
        },
        {
          "slug": "text-soft",
          "color": "#4a4a4a",
          "name": "Text"
        },
        {
          "slug": "text-muted",
          "color": "#A2A2A2",
          "name": "Text"
        },
        {
          "slug": "text-negative",
          "color": "rgba(255, 255, 255, 1)",
          "name": "Text Negative "
        },
        {
          "slug": "text-negative-80",
          "color": "rgba(255, 255, 255, 0.8)",
          "name": "Text Negative 80%"
        },
        {
          "slug": "foreground",
          "color": "#333333",
          "name": "Foreground"
        },
        {
          "slug": "header-bg",
          "color": "#ffffff",
          "name": "Header Background"
        },
        {
          "slug": "header-text",
          "color": "#000000",
          "name": "Header Text"
        },
        {
          "slug": "element-bg",
          "color": "#f5f5f5",
          "name": "Elements background"
        },
        {
          "slug": "element-contrast",
          "color": "#e2e2e2",
          "name": "Elements contrast"
        },
        {
          "slug": "element-border",
          "color": "#9b9b9b",
          "name": "Elements border"
        }
      ]
    },
    "custom": {
      "breakpoint": {
        "mobile": "782px"
      },
      "header": {
        "height": "7.5rem",
        "mobile-pad-x": "2.4rem",
        "mobile-pad-y": "1rem"
      },
      "elements": {
        "toggle-width": "5rem",
        "sidebar-width": "clamp(20rem,20vw,24rem)"
      },
      "layout": {
        "col-side": "clamp(20rem,20vw,24rem)",
        "col-wiki": "34rem"
      }
    }
  },
  "styles": {
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--monospace)"
    },
    "blocks": {
      "core/button": {
        "color": {
          "text": "#FFFFFF",
          "background": "var(--wp--preset--color--primary)"
        }
      }
    },
    "spacing": {
      "blockGap": "0",
      "margin": {
        "top": "0",
        "bottom": "0",
        "left": "0",
        "right": "0"
      },
      "padding": {
        "left": "var(--wp--preset--spacing--50)",
        "right": "var(--wp--preset--spacing--50)"
      }
    }
  }
}
