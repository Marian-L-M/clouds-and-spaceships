{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "cns-theme/cns-header",
  "version": "0.1.0",
  "title": "CNS Header",
  "category": "design",
  "icon": "layout",
  "description": "Custom header for CNS theme",
  "example": {},
  "supports": {
    "html": false,
    "interactivity": true
  },
  "attributes": {
    "backgroundColor": {
      "type": "string",
      "default": ""
    },
    "textColor": {
      "type": "string",
      "default": ""
    }
  },
  "textdomain": "cns-theme",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "editorStyle": "file:./index.css",
  "render": "file:./render.php",
  "viewScriptModule": "file:./view.js"
}
